PORT=port
TELEGRAM_BOT_TOKEN=replace-with-local-dev-token
TELEGRAM_WEBHOOK_SECRET=replace-with-local-dev-secret
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_REPORT_CHAT_ID=123456789
EZBOOKKEEPING_API_TOKEN=replace-after-generating-ezbookkeeping-api-token
ASSISTANT_INTERNAL_TOKEN=replace-with-local-dev-internal-token
PORTFOLIO_ACCOUNT_IDENTITY_SALT=replace-with-local-dev-portfolio-salt
PORTFOLIO_WRITER_LEASE_MINUTES=30
PORTFOLIO_SNAPSHOT_RETENTION_DAYS=30
PORTFOLIO_EXPORT_RETENTION_DAYS=90
PORTFOLIO_RAW_IMPORT_RETENTION_DAYS=90
PORTFOLIO_FIXTURE_BROKER_ID=fixture
PORTFOLIO_FIXTURE_ACCOUNT_ALIAS=fixture-main
PORTFOLIO_FIXTURE_ADAPTER_ID=fixture-broker
PORTFOLIO_FIXTURE_SCENARIO=complete
PORTFOLIO_FIXTURE_REQUESTED_AT=2026-06-06T02:00:00.000Z
PORTFOLIO_EXPORT_TARGET=wealthfolio-local
PORTFOLIO_EXPORT_FORMAT=json
PORTFOLIO_EXPORT_INCLUDE_PARTIAL_OR_STALE=false
SINOPAC_API_KEY=replace-with-sinopac-api-key
SINOPAC_SECRET_KEY=replace-with-sinopac-secret-key
SINOPAC_CA_PATH=/run/secrets/sinopac/sinopac_API_credential.pfx
SINOPAC_CA_PASSWORD=replace-with-sinopac-ca-password
SINOPAC_PERSON_ID=replace-with-owner-id-if-required-by-ca
SINOPAC_ACCOUNT_ALIAS=sinopac-main
SINOPAC_SHIOAJI_COMMAND=/app/scripts/sinopac_shioaji_snapshot.py
EZBOOKKEEPING_SECRET_KEY=replace-with-local-dev-ezbookkeeping-secret
WEALTHFOLIO_SECRET_KEY=replace-with-local-dev-wealthfolio-secret
WEALTHFOLIO_AUTH_REQUIRED=false
WEALTHFOLIO_AUTH_PASSWORD_HASH=replace-with-local-dev-password-hash
WEALTHFOLIO_DISPLAY_CURRENCY=TWD
WEALTHFOLIO_EXCHANGE_RATES=USD:TWD=32.1
EZBOOKKEEPING_ACCOUNT_IDS={}
EZBOOKKEEPING_CATEGORY_IDS={}
# Local ezBookkeeping UI credentials reference only; Docker Compose and the
# assistant do not consume these values.
EZBOOKKEEPING_LOCAL_USERNAME=replace-with-local-owner-username
EZBOOKKEEPING_LOCAL_PASSWORD=replace-with-local-owner-password
LLM_ENABLED=false
LLM_SUMMARY_ENDPOINT=
LLM_API_KEY=
